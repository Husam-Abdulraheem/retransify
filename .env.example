# Environment Variables — Retransify
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and should NEVER be committed.

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Choose your AI provider: 'gemini' or 'groq'
AI_PROVIDER=gemini

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Get your Gemini key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Get your Groq key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
