{
  "name": "retransify",
  "version": "1.0.0",
  "description": "CLI tool that autonomously converts React web projects into production-ready React Native (Expo) apps using AI and LangGraph agentic workflows.",
  "bin": {
    "retransify": "./cli.js"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.28.3",
    "@google/genai": "^1.38.0",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.2",
    "commander": "^14.0.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.1",
    "glob": "^11.0.3",
    "groq-sdk": "^0.37.0",
    "langchain": "^1.2.30",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^27.0.2",
    "zod": "^3.23.8"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "react-native",
    "expo",
    "react",
    "migration",
    "cli",
    "ai",
    "langgraph",
    "code-conversion",
    "nativewind",
    "expo-router"
  ],
  "author": "Husam Abdulraheem",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src/",
    "assets/",
    "cli.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Husam-Abdulraheem/retransify.git"
  },
  "bugs": {
    "url": "https://github.com/Husam-Abdulraheem/retransify/issues"
  },
  "homepage": "https://github.com/Husam-Abdulraheem/retransify#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "memory-vector-store": "^1.0.10",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{js,mjs,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
